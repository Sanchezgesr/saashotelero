# ============================================
# HControl — Environment Variables Template
# ============================================
# Copy this file to .env.local and fill values.
# Vars prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ============================================

# Supabase (obligatorio)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=HControl

# Sentry (opcional)
NEXT_PUBLIC_SENTRY_DSN=

# Upstash Redis (opcional, para rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Guest encryption key (obligatorio para cifrar datos sensibles de huéspedes)
# Generar con: openssl rand -hex 32
GUEST_ENCRYPTION_KEY=

# Resend API key (opcional, para envío de emails)
RESEND_API_KEY=
